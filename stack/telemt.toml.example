# Copy to telemt.toml and replace the secret with your own (openssl rand -hex 16).
# The domain in censorship.tls_domain must match the HostSNI rule in traefik/dynamic/tcp.yml.

show_link = ["docker"]

[general]
prefer_ipv6 = false
fast_mode = true
use_middle_proxy = false

[general.modes]
classic = false
secure = false
tls = true

[server]
port = 1234
listen_addr_ipv4 = "0.0.0.0"
listen_addr_ipv6 = "::"
# Enable PROXY protocol when behind Traefik/HAProxy to receive real client IPs
proxy_protocol = true

[censorship]
tls_domain = "1c.ru"
mask = true
mask_port = 443
fake_cert_len = 2048

[access]
replay_check_len = 65536
ignore_time_skew = false

[access.users]
docker = "REPLACE_WITH_32_HEX_CHARS"

[[upstreams]]
type = "direct"
enabled = true
weight = 10
